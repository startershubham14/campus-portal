# Backend environment variables
# Copy this file to `.env` and fill in real values.

#  Database 
# Async PostgreSQL connection string (note the +asyncpg driver).
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<db_name>
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/campus_portal

#  JWT 
# Secret used to sign auth tokens. Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

#  AWS S3 (course materials & submissions) 
# IAM user credentials with s3:PutObject / GetObject / DeleteObject on the bucket.
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=your-bucket-name

# --- Environment ------------------------------------------------------------
# False locally (HTTP). Set True in production (HTTPS) so the auth cookie is
# sent with the Secure flag — required for cookies to work over HTTPS.
IS_PRODUCTION=False
